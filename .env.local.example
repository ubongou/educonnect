# Supabase — from `supabase start` (local) or project settings (cloud)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (transactional email) — https://resend.com
# Until RESEND_API_KEY is set the lesson-report send is a no-op (logged, not failed).
RESEND_API_KEY=
RESEND_FROM=EduConnect <no-reply@joineduconnect.com>

# Public URL used in transactional emails and OAuth redirects.
# Set to the deployed origin in production (no trailing slash).
APP_URL=http://localhost:3000
