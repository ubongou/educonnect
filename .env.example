# Production environment template — copy into the Vercel project Environment
# Variables tab (or `vercel env pull`) and replace each placeholder.
#
# Local dev uses .env.local — see .env.local.example.

# ----- Supabase ---------------------------------------------------------------
# Supabase Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# Supabase Project Settings → API → anon / public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Supabase Project Settings → API → service_role key (NEVER expose client-side)
SUPABASE_SERVICE_ROLE_KEY=

# ----- Resend ----------------------------------------------------------------
# Resend dashboard → API Keys.
# If unset, lesson-report emails are skipped (the report still saves and is
# visible from /admin/reports, where you can resend later).
RESEND_API_KEY=
# Verified sender, e.g. "EduConnect <no-reply@joineduconnect.com>".
# Falls back to "EduConnect <onboarding@resend.dev>" for first-run testing.
RESEND_FROM_EMAIL=EduConnect <no-reply@joineduconnect.com>

# ----- App -------------------------------------------------------------------
# Public origin used in email links. No trailing slash.
APP_URL=https://joineduconnect.com
